# =================================================================
# LiveKit Configuration (for agent.py - voice agent)
# Get these from https://cloud.livekit.io
# =================================================================
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# =================================================================
# LLM Configuration (for web_agent.py - text chat)
# =================================================================
# Local Ollama (default)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Cloud LLM option (uncomment to use instead of Ollama)
# OPENAI_API_KEY=your_openai_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Groq (free tier - for STT)
GROQ_API_KEY=your_groq_key

# =================================================================
# Server Configuration
# =================================================================
HOST=0.0.0.0
PORT=5000
FLASK_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# =================================================================
# CORS - Multi-Device Access
# =================================================================
# Allow all origins (development)
CORS_ORIGINS=*
# Production: specify your frontend URL
# CORS_ORIGINS=https://your-app.netlify.app,https://yourdomain.com
