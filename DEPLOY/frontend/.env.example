# =================================================================
# LiveKit Configuration (REQUIRED for multi-device voice)
# Get these from https://cloud.livekit.io
# =================================================================
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here
LIVEKIT_URL=wss://your-project.livekit.cloud

# =================================================================
# Backend Server URL (where your Python server runs)
# =================================================================
# This tells the React frontend where to send API requests
# Set this to your backend server's URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# For LiveKit voice features
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# =================================================================
# Agent Configuration
# =================================================================
# Leave AGENT_NAME blank for automatic dispatch
# Or provide a specific agent name for explicit dispatch
AGENT_NAME=

# =================================================================
# Netlify/Deployment
# =================================================================
# Set to 'true' when deploying to Netlify
NETLIFY=false

# =================================================================
# Optional: Sandbox Configuration
# =================================================================
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=
